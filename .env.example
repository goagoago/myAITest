# ⚠️ 安全提示：不要将真实密钥提交到 git！
# 复制此文件为 .env.local 后填入真实值

# 智谱API密钥 - 在Vercel项目设置 > Environment Variables 中配置
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your_zhipu_api_key_here

# 硅基流动API密钥 - 用于AI图片/去水印
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 前端环境变量（VITE_ 前缀会暴露到浏览器，请勿放敏感信息）
# VITE_APP_URL=https://www.2074912.xyz
